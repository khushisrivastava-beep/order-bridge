{
  "version": 2,
  "rewrites": [
    { "source": "/api/login",    "destination": "/api/login.js" },
    { "source": "/api/callback", "destination": "/api/callback.js" },
    { "source": "/api/session",  "destination": "/api/session.js" },
    { "source": "/(.*)",         "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
